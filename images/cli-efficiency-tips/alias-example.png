<svg width="800" height="500" xmlns="http://www.w3.org/2000/svg">
  <rect width="100%" height="100%" fill="#1a1a2e"/>
  <text x="400" y="180" font-family="Arial, sans-serif" font-size="24" fill="#4a9eff" text-anchor="middle">常用 Alias 配置</text>
  <text x="400" y="230" font-family="Arial, sans-serif" font-size="14" fill="#888" text-anchor="middle">alias ll='ls -lah'</text>
  <text x="400" y="260" font-family="Arial, sans-serif" font-size="14" fill="#888" text-anchor="middle">alias dc='docker-compose'</text>
  <text x="400" y="290" font-family="Arial, sans-serif" font-size="14" fill="#888" text-anchor="middle">alias gst='git status'</text>
  <text x="400" y="340" font-family="Arial, sans-serif" font-size="12" fill="#666" text-anchor="middle">[占位图片 - 请替换为终端alias配置截图]</text>
</svg>