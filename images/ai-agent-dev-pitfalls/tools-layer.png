<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400">
  <rect width="800" height="400" fill="#16213e"/>
  <text x="400" y="60" text-anchor="middle" fill="#eee" font-size="24" font-family="sans-serif">工具层架构</text>
  <rect x="100" y="120" width="600" height="200" rx="12" fill="#1a1a2e" stroke="#4a4e69"/>
  <text x="400" y="155" text-anchor="middle" fill="#aaa" font-size="16">Agent 核心逻辑</text>
  <rect x="130" y="180" width="140" height="100" rx="8" fill="#4a4e69"/>
  <text x="200" y="225" text-anchor="middle" fill="#fff" font-size="14">工具 A</text>
  <text x="200" y="250" text-anchor="middle" fill="#aaa" font-size="12">有文档</text>
  <text x="200" y="270" text-anchor="middle" fill="#aaa" font-size="12">有校验</text>
  <rect x="330" y="180" width="140" height="100" rx="8" fill="#4a4e69"/>
  <text x="400" y="225" text-anchor="middle" fill="#fff" font-size="14">工具 B</text>
  <text x="400" y="250" text-anchor="middle" fill="#aaa" font-size="12">有文档</text>
  <text x="400" y="270" text-anchor="middle" fill="#aaa" font-size="12">有校验</text>
  <rect x="530" y="180" width="140" height="100" rx="8" fill="#4a4e69"/>
  <text x="600" y="225" text-anchor="middle" fill="#fff" font-size="14">工具 C</text>
  <text x="600" y="250" text-anchor="middle" fill="#aaa" font-size="12">有文档</text>
  <text x="600" y="270" text-anchor="middle" fill="#aaa" font-size="12">有校验</text>
  <text x="400" y="350" text-anchor="middle" fill="#888" font-size="16">每个工具都是一个独立的 API</text>
</svg>
